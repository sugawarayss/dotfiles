{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(bat:*)",
      "Bash(colordiff:*)",
      "Bash(cut:*)",
      "Bash(diff:*)",
      "Bash(docker ps:*)",
      "Bash(docker compose exec:*)",
      "Bash(docker compose logs:*)",
      "Bash(echo:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(git --version)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git pull:*)",
      "Bash(git rev-parse *)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status)",
      "Bash(git switch *)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(lsd:*)",
      "Bash(mise run:*)",
      "Bash(mkdir:*)",
      "Bash(node --version)",
      "Bash(pnpm run:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm --version)",
      "Bash(python3 --version)",
      "Bash(sd:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(task:*)",
      "Bash(tee:*)",
      "Bash(tr:*)",
      "Bash(uniq *)",
      "Bash(uv run:*)",
      "Bash(uv pip list:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs:*)",
      "mcp__aws-knowledge__aws___search_documentation",
      "mcp__aws-knowledge__aws___recommend",
      "mcp__aws-knowledge__aws___read_documentation",
      "mcp__aws-knowledge__aws___get_regional_availability",
      "mcp__aws-knowledge__aws___list_regions",
      "mcp__serena__list_dir",
      "mcp__serena__find_file",
      "mcp__serena__search_for_pattern",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__find_symbol",
      "mcp__serena__find_referencing_symbols",
      "mcp__serena__replace_symbol_body",
      "mcp__serena__insert_after_symbol",
      "mcp__serena__insert_before_symbol",
      "mcp__serena__rename_symbol",
      "mcp__serena__write_memory",
      "mcp__serena__read_memory",
      "mcp__serena__list_memories",
      "mcp__serena__delete_memory",
      "mcp__serena__edit_memory",
      "mcp__serena__activate_project",
      "mcp__serena__get_current_config",
      "mcp__serena__check_onboarding_performed",
      "mcp__serena__onboarding",
      "mcp__serena__think_about_collected_information",
      "mcp__serena__think_about_task_adherence",
      "mcp__serena__think_about_whether_you_are_done",
      "mcp__serena__initial_instructions",
      "Read(~/**)",
      "Write(/tmp/**)"
    ],
    "deny": [
      "NotebookEdit",
      "Bash(* .env*)",
      "Bash(* ~/.aws/*)",
      "Bash(* ~/.config/gh/*)",
      "Bash(* ~/.git-credentials)",
      "Bash(* ~/.netrc)",
      "Bash(* ~/.npmrc)",
      "Bash(* ~/.ssh/*)",
      "Bash(curl *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wget *)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(npm remove:*)",
      "Bash(npm uninstall:*)",
      "Bash(open *)",
      "Bash(osascript *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(rm:*)",
      "Bash(rmdir *)",
      "Bash(rsync * --delete*)",
      "Bash(scp *)",
      "Bash(security *)",
      "Bash(shred *)",
      "Bash(ssh *)",
      "Bash(su *)",
      "Bash(sudo:*)",
      "Bash(telnet *)",
      "Bash(terraform apply *)",
      "Bash(unlink *)",
      "Bash(uv remove *)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets/**)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.config/fish/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/id_ed25519)",
      "Read(**/id_rsa)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.npmrc)",
      "Read(~/.ssh/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)",
      "Write(~/.bashrc)",
      "Write(~/.zshrc)",
      "Write(~/.config/fish/**)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/002_InstructionLoaded.wav"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/001_Notification.wav"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/003_PermissionRequest.wav"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/006_PostToolUse_Read.wav"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/007_PostToolUse_Write.wav"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/004_PreToolUse_MCP.wav"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/005_PreToolUse_Bash.wav"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/sugawarayss/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/009_Stop.wav"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/008_SubagentStart.wav"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-powerline --style powerline --theme tokyo-night"
  },
  "enabledPlugins": {
    "crit@crit": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "crit": {
      "source": {
        "source": "github",
        "repo": "tomasz-tomczyk/crit"
      }
    }
  },
  "language": "japanese",
  "tui": "fullscreen",
  "editorMode": "vim"
}
