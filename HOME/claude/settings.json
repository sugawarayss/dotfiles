{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(bat:*)",
      "Bash(colordiff:*)",
      "Bash(cut *)",
      "Bash(diff *)",
      "Bash(docker compose exec:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose:*)",
      "Bash(echo *)",
      "Bash(fd:*)",
      "Bash(find *)",
      "Bash(find:*)",
      "Bash(gh api *)",
      "Bash(gh issue *)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr view:*)",
      "Bash(git --version)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git merge-base *)",
      "Bash(git pull *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status)",
      "Bash(git switch *)",
      "Bash(grep *)",
      "Bash(grep:*)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(lsd:*)",
      "Bash(mise run:*)",
      "Bash(mkdir:*)",
      "Bash(node --version)",
      "Bash(pnpm *)",
      "Bash(pnpm --version)",
      "Bash(python3 --version)",
      "Bash(rg:*)",
      "Bash(say:*)",
      "Bash(sd:*)",
      "Bash(sed *)",
      "Bash(sed:*)",
      "Bash(sort *)",
      "Bash(task:*)",
      "Bash(tee *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(uv run:*)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(xargs *)",
      "Read",
      "Write(/tmp/**)"
    ],
    "deny": [
      "Bash(* .env*)",
      "Bash(* ~/.aws/*)",
      "Bash(* ~/.config/gh/*)",
      "Bash(* ~/.git-credentials)",
      "Bash(* ~/.netrc)",
      "Bash(* ~/.npmrc)",
      "Bash(* ~/.ssh/*)",
      "Bash(curl *)",
      "Bash(find * -delete*)",
      "Bash(git push *)",
      "Bash(git push --force *)",
      "Bash(git rebase: *)",
      "Bash(git reset *)",
      "Bash(git reset --hard *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(npm remove *)",
      "Bash(npm uninstall: *)",
      "Bash(open *)",
      "Bash(osascript *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(rm *)",
      "Bash(rm -fr *)",
      "Bash(rm -r:*)",
      "Bash(rm -rf *)",
      "Bash(rmdir *)",
      "Bash(rsync * --delete*)",
      "Bash(scp *)",
      "Bash(security *)",
      "Bash(shred *)",
      "Bash(ssh *)",
      "Bash(su *)",
      "Bash(sudo:*)",
      "Bash(telnet *)",
      "Bash(unlink *)",
      "Bash(uv remove *)",
      "Bash(wget *)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(/secrets/**)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(/secrets/**)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.npmrc)",
      "Read(~/.ssh/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(/secrets/**)",
      "Write(~/.bashrc)",
      "Write(~/.zshrc)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "say -v Kyoko \"作業について聞きたいことがあります\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "say -v Kyoko \"承認してほしいです\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "say -v Kyoko \"MCPサーバーを使いますね\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "say -v Kyoko \"作業が完了しました\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-powerline --style powerline --theme tokyo-night"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "language": "japanese",
  "editorMode": "vim"
}
