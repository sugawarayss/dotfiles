{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(bat:*)",
      "Bash(colordiff:*)",
      "Bash(cut:*)",
      "Bash(diff:*)",
      "Bash(docker ps:*)",
      "Bash(docker compose exec:*)",
      "Bash(docker compose logs:*)",
      "Bash(echo:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(git --version)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git pull:*)",
      "Bash(git rev-parse *)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status)",
      "Bash(git switch *)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(lsd:*)",
      "Bash(mise run:*)",
      "Bash(mkdir:*)",
      "Bash(node --version)",
      "Bash(pnpm run:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm --version)",
      "Bash(python3 --version)",
      "Bash(sd:*)",
      "Bash(sed *)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(task:*)",
      "Bash(tee:*)",
      "Bash(tr:*)",
      "Bash(uniq *)",
      "Bash(uv run:*)",
      "Bash(uv pip list:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs:*)",
      "Read(~/**)",
      "Write(/tmp/**)"
    ],
    "deny": [
      "NotebookEdit",
      "Bash(* .env*)",
      "Bash(* ~/.aws/*)",
      "Bash(* ~/.config/gh/*)",
      "Bash(* ~/.git-credentials)",
      "Bash(* ~/.netrc)",
      "Bash(* ~/.npmrc)",
      "Bash(* ~/.ssh/*)",
      "Bash(curl *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wget *)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git reset --hard *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(npm remove:*)",
      "Bash(npm uninstall:*)",
      "Bash(open *)",
      "Bash(osascript *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(rm:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(rmdir *)",
      "Bash(rsync * --delete*)",
      "Bash(scp *)",
      "Bash(security *)",
      "Bash(shred *)",
      "Bash(ssh *)",
      "Bash(su *)",
      "Bash(sudo:*)",
      "Bash(telnet *)",
      "Bash(terraform apply *)",
      "Bash(unlink *)",
      "Bash(uv remove *)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(/secrets/**)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/secrets/**)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.npmrc)",
      "Read(~/.ssh/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(/secrets/**)",
      "Write(~/.bashrc)",
      "Write(~/.zshrc)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/001_Notification.wav"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/002_InstructionsLoaded.wav"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/003_PermissionRequest.wav"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/004_PreToolUse_mcp.wav"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/006_PostToolUse_Read.wav"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/007_PostToolUse_Write.wav"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/008_SubagentStart.wav"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hook_voices/009_Stop.wav"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-powerline --style powerline --theme tokyo-night"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "language": "japanese",
  "tui": "fullscreen",
  "editorMode": "vim"
}
