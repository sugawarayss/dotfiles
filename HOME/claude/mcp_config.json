{
  "globalShortcut": "Alt+Ctrl+Tab",
  "mcpServers": {
    "aws-knowledge": {
      "args": [
        "fastmcp",
        "run",
        "https://knowledge-mcp.global.api.aws"
      ],
      "autoApprove": [
        "aws___search_documentation",
        "aws___recommend",
        "aws___read_documentation",
        "aws___get_regional_availability",
        "aws___list_regions"
      ],
      "command": "uvx"
    },
    "aws-terraform": {
      "args": [
        "awslabs.terraform-mcp-server@latest"
      ],
      "autoApprove": [
        "ExecuteTerraformCommand",
        "SearchAwsProviderDocs",
        "SearchAwsccProviderDocs",
        "SearchSpecificAwsIaModules",
        "SearchUserProvidedModule",
        "RunCheckovScan"
      ],
      "command": "uvx",
      "disabled": false,
      "disabled_tools": [],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "command": "npx",
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "128000"
      }
    },
    "filesystem": {
      "command": "/Users/sugawarayss/.local/share/mise/shims/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/sugawarayss/PROJECTS/"
      ],
      "autoApprove": [
        "read_file",
        "read_multiple_files",
        "list_directory",
        "search_files",
        "get_file_info",
        "list_allowed_directories",
        "directory_tree",
        "move_file",
        "write_file",
        "create_directory",
        "edit_file",
        "list_directory_with_sizes",
        "read_media_file",
        "read_text_file"
      ]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide"
      ],
      "autoApprove": [
        "find_file",
        "find_symbol",
        "list_dir",
        "read_memory",
        "write_memory",
        "list_memories",
        "think_about_collected_information",
        "activate_project",
        "onboarding",
        "search_for_pattern"
      ]
    },
    "markitdown": {
      "args": [
        "markitdown-mcp==0.0.1a4"
      ],
      "autoApprove": [
        "convert_to_markdown"
      ],
      "command": "uvx",
      "type": "stdio"
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
      "autoApprove": [
        "browser_click",
        "browser_wait_for",
        "browser_type",
        "browser_take_screenshot",
        "browser_press_key",
        "browser_hover",
        "browser_evaluate",
        "browser_drag",
        "browser_console_messages",
        "browser_close"
      ],
      "command": "npx"
    }
  }
}
