{
  "link": {
    "prefix": ".link",
    "body": [
      "[${1}](${2})"
    ],
    "description": "マークダウンリンク"
  },
  "code-block": {
    "prefix": ".codeblock",
    "body": [
      "```${0}",
      "```"
    ],
    "description": "コードブロック"
  },
  "image-link": {
    "prefix": ".image",
    "body": [
      "![${1}](${2})"
    ],
    "description": "マークダウン画像リンク"
  },
  "table-basic": {
    "prefix": ".table",
    "body": [
      "| ${1} |",
      "| --- |",
      "| ${2} |"
    ],
    "description": "テーブル基本形"
  },
  "table-ext": {
    "prefix": ".table-ext-col",
    "body": [
      " ${1} |"
    ],
    "description": "テーブル追加列(add Header row)"
  },
  "table-ext-sep": {
    "prefix": ".table-ext-sep",
    "body": [
      " --- |"
    ],
    "description": "テーブル追加(add separater row)"
  },
  "table-ext-cel": {
    "prefix": ".table-ext-cel",
    "body": [
      " $0 |"
    ],
    "description": "テーブルセル追加(append cell)"
  },
  "details": {
    "prefix": ".details",
    "body": [
      "<details>",
      "<summary>${1}</summary>",
      "",
      "${2}",
      "",
      "</details>"
    ],
    "description": "折りたたみ要素"
  },
  "warning-call-out": {
    "prefix": ".callout-warning",
    "body": [
      "> [!WARNING]",
      "> ",
      "> $0"
    ],
    "description": "コールアウト(Warning)"
  },
  "note-call-out": {
    "prefix": ".callout-note",
    "body": [
      "> [!NOTE]",
      "> ",
      "> $0"
    ],
    "description": "コールアウト(Note)"
  },
  "check-box": {
    "prefix": ".check",
    "body": [
      "- [  ] $0"
    ],
    "description": "チェックボックス"
  }
}
