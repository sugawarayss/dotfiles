{
  "link": {
    "prefix": ".link",
    "body": [
      "[${1:label}](${2:url})"
    ],
    "description": "マークダウンリンク"
  },
  "image-link": {
    "prefix": ".image",
    "body": [
      "![${1:label}](${2:url})"
    ],
    "description": "マークダウン画像リンク"
  },
  "table-basic": {
    "prefix": ".table",
    "body": [
      "| ${1:col} |",
      "| --- |",
      "| ${2: value} |"
    ],
    "description": "テーブル基本形"
  },
  "table-ext": {
    "prefix": ".table-ext-col",
    "body": [
      " ${1:col} |"
    ],
    "description": "テーブル追加列(add Header row)"
  },
  "table-ext-sep": {
    "prefix": ".table-ext-sep",
    "body": [
      " --- |"
    ],
    "description": "テーブル追加(add separater row)"
  },
  "table-ext-cel": {
    "prefix": ".table-ext-cel",
    "body": [
      " ${1:val} |"
    ],
    "description": "テーブルセル追加(append cell)"
  },
  "details": {
    "prefix": ".details",
    "body": [
      "<details>",
      "<summary>${1:title}</summary>",
      "",
      "${2:content}",
      "",
      "</details>"
    ],
    "description": "折りたたみ要素"
  },
  "warning-call-out": {
    "prefix": ".callout-warning",
    "body": [
      "> [!WARNING]",
      "> ",
      "> ${1:content}"
    ],
    "description": "コールアウト(Warning)"
  },
  "note-call-out": {
    "prefix": ".callout-note",
    "body": [
      "> [!NOTE]",
      "> ",
      "> ${1:content}"
    ],
    "description": "コールアウト(Note)"
  }
}
