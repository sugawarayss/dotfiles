{
  "date-iso": {
    "prefix": "date-iso",
    "body": [
      "${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}T${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}"
    ],
    "description": "ISO 8601形式の日付と時刻"
  },
  "date": {
    "prefix": "date",
    "body": [
      "${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}"
    ],
    "description": "日付(YYYY-MM-DD)"
  },
  "time": {
    "prefix": "time",
    "body": [
      "${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}"
    ],
    "description": "時刻(HH:MM:SS)"
  },
  "datetime": {
    "prefix": "datetime",
    "body": [
      "${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE} ${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}"
    ],
    "description": "日付と時刻(YYYY-MM-DD HH:MM:SS)"
  },
  "uuid": {
    "prefix": "uuid",
    "body": [
      "${UUID}"
    ],
    "description": "UUIDv4"
  },
  "taskfile": {
    "prefix": "taskfile",
    "body": [
      "version: '3'",
      "",
      "tasks:",
      "  default:",
      "    desc: 全てのタスクを表示する",
      "    cmds:",
      "      - task -l --sort none",
      "",
      "  lint_ruff:",
      "    desc: ruffによるチェックの実行",
      "    cmds:",
      "      - uvx ruff check --config ./pyproject.toml",
      "",
      "  install_stubs:",
      "    desc: mypy 型チェック用のスタブのインストール",
      "    preconditions:",
      "      - sh: '[ -d .mypy_cache/ ]'",
      "        msg: \".mypy_cache does not exist\"",
      "      - sh: '[ -f .mypy_cache/missing_stubs ]'",
      "        msg: \".mypy_cache/misssing_stubs does not exist\"",
      "    cmds:",
      "      - cat ./mypy_cache/missing_stubs | xargs uv pip install",
      "",
      "  lint_mypy:",
      "    desc: mypyによる型チェックの実行",
      "    cmds:",
      "      - \"uv run mypy --config-file ./pyproject.toml .\"",
      "",
      "  lint:",
      "    desc: ruff と mypy によるコードリンティングの実行",
      "    deps:",
      "      - task: lint_ruff",
      "      - task: lint_mypy",
      "",
      "  format:",
      "    desc: ruff によるコードフォーマットの実行",
      "    cmds:",
      "      - uvx ruff format --config ./pyproject.toml"
    ]
  },
  "pre-commit-settings": {
    "prefix": "pre-commit-config",
    "body": [
      "# See https://pre-commit.com for more information",
      "# See https://pre-commit.com/hooks.html for more hooks",
      "repos:",
      "  - repo: https://github.com/astral-sh/ruff-pre-commit",
      "    # TODO: ruffバージョンに合わせる",
      "    rev: v0.8.1",
      "    hooks:",
      "      # ruff によるリンティング",
      "      - id: ruff",
      "        entry: ruff check --force-exclude",
      "        language: python",
      "        types_or: [python, pyi]",
      "        args: [--config=pyproject.toml, --extend-select=I, --fix]",
      "      # ruff によるコードフォーマト",
      "      - id: ruff-format",
      "        entry: ruff format --force-exclude",
      "        language: python",
      "        types_or: [python, pyi]",
      "        args: [--config=pyproject.toml]",
      "",
      "  - repo: https://github.com/pre-commit/mirrors-mypy",
      "    # TODO: mypyバージョンに合わせる",
      "    rev: v1.13.0",
      "    hooks:",
      "      # mypy による静的型チェック",
      "      - id: mypy",
      "        entry: mypy",
      "        language: python",
      "        args: [--install-types, --non-interactive, --config-file=pyproject.toml]",
      "        # TODO: pydantic や sqlmodel のバージョンに合わせる",
      "        additional_dependencies: [\"pydantic>=2.10.3\", \"sqlmodel>=0.5.1\"]",
      "        exclude: \"^tests/\""
    ]
  }
}
