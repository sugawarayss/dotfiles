{
  "pytest-settings": {
    "prefix": ".pytest-pyproject",
    "body": [
      "[tool.pytest.ini_options]",
      "addopts = [",
      "  #  未登録のマーカーが存在する場合にエラーを発生させる",
      "  \"--strict-markers\",",
      "  # 設定ファイルにミスがある場合にエラーを発生させる",
      "  \"--strict-config\",",
      "  # テスト実行時にサマリを表示する",
      "  \"-ra \",",
      "]",
      "testpaths = [",
      "  \"tests\"",
      "]",
      "markers = [\"slow: mark test as slow to run\"]",
      "# 非同期テストを含む場合(要pytest-asyncio)",
      "#asyncio_mode = \"auto\"",
      "filterwarnngs = [",
      "  \"ignore::DeprecationWarning\",",
      "  \"ignore::_pytest.warning_types.PytestUnknownMArkWarning\"",
      "]",
      "log_date_format = \"%Y-%m-%d %H:%M:%S\""
    ]
  },
  "ruff-settings": {
    "prefix": ".ruff-pyproject",
    "body": [
      "[tool.ruff]",
      "target-version = \"py313\"",
      "# 1行の文字数",
      "line-length = 150",
      "# インデントの空白文字数",
      "indent-width = 4",
      "# .gitignoreを尊重する",
      "respect-gitignore = true",
      "# リンティングやフォーマッティングの対象から除外するファイルパターン",
      "exclude = [",
      "  \".bzr\",",
      "  \".direnv\",",
      "  \".eggs\",",
      "  \".git\",",
      "  \".git-rewrite\",",
      "  \".hg\",",
      "  \".mypy_cache\",",
      "  \".nox\",",
      "  \".pants.d\",",
      "  \"pytype\",",
      "  \"ruff_cache\",",
      "  \".svn\",",
      "  \".tox\",",
      "  \".venv\",",
      "  \"__pypackages__\",",
      "  \"_build\",",
      "  \"buck-out\",",
      "  \"build\",",
      "  \"dist\",",
      "  \"node_modules\",",
      "  \"venv\",",
      "  \"migration/**\",",
      "]",
      "# 自動修正する(できるもののみ)",
      "fix = true",
      "# プレビューモードは無効にする",
      "preview = false",
      "",
      "",
      "[tool.ruff.lint]",
      "# 適用するルール",
      "select = [\"ALL\"]",
      "# 適用しないルール",
      "ignore = [",
      "  \"A003\",   # flake8-builtins(builtin-attribute-shadowing)",
      "  \"ARG\",    # flake8-unused-arguments",
      "  \"B\",      # flake8-bugbear",
      "  \"BLE\",    # flake8-blind-except",
      "  \"C4\",     # flake8-comprehensions",
      "  \"COM\",    # flake8-commas",
      "  \"CPY\",    # flake8-copyright",
      "  \"D\",      # pydocstyle",
      "  \"DJ\",     # flake8-django",
      "  \"DTZ\",    # flake8-datetimez",
      "  \"E501\",   # pydocstyle(line-too-long)",
      "  \"EM\",     # flake8-errmsg",
      "  \"ERA\",    # eradicate",
      "  \"EXE\",    # flake8-executable",
      "  \"FA\",     # flake8-future-annotation",
      "  \"FBT\",    # flake8-boolean-trap",
      "  \"FIX\",    # flake8-fixme",
      "  \"FLY\",    # flynt",
      "  \"G\",      # flake8-logging-format",
      "  \"ISC\",    # flake8-implicit-str-concat",
      "  \"N815\",   # pep8-naming(mixed-case-variable-in-class-scope)",
      "  \"PTH\",    # flake8-use-pathlib",
      "  \"RET504\", # flake8-return(Unnecessary assignment to `response` before `return` statement)",
      "  \"RUF001\", # Ruff-specific rules(ambigous-unicode-character-string)",
      "  \"S\",      # flake8-bandit",
      "  \"T10\",    # flake8-debugger",
      "  \"T20\",    # flake8-print",
      "  \"TD\",     # flake8-todo",
      "  \"TID\",    # flake8-tidy-imports",
      "  \"TRY\",    # tryceratops",
      "  \"YTT\",    # flake8-2020",
      "]",
      "# リンティング対象から除外するファイルパターン",
      "exclude = [\"tests/**\"]",
      "# 安定しないルールは適用しない",
      "preview = false",
      "",
      "",
      "[tool.ruff.lint.isort]",
      "# importのソートを大文字/小文字を考慮する",
      "case-sensitive = true",
      "# インポート文を1行にまとめる",
      "combine-as-imports = true",
      "# インポート後の空行数",
      "lines-after-imports = 2",
      "# 末尾のカンマで改行する",
      "split-on-trailing-comma = true",
      "# エイリアスを使用する場合に強制的に改行する",
      "force-wrap-aliases = true",
      "# ソートするインポートの順序",
      "section-order = [",
      "  \"future\",",
      "  \"standard-library\",",
      "  \"third-party\",",
      "  \"first-party\",",
      "  \"local-folder\",",
      "]",
      "",
      "",
      "[tool.ruff.format]",
      "# インデントは空白",
      "indent-style = \"space\"",
      "# 改行コードはLFで統一する",
      "line-ending = \"lf\"",
      "# 安定していないルールは適用しない",
      "preview = true",
      "# docstring内のコードスニペットもフーマットする",
      "docstring-code-format = true",
      "# ダブルクォートで統一する",
      "quote-style = \"double\"",
      "# docstring内のコードスニペットの文字数上限",
      "docstring-code-line-length = 150",
      "# 末尾のカンマは無視しない",
      "skip-magic-trailing-comma = false",
      "# フォーマット対象から除外するファイルパターン",
      "exclude = [\"migration/**\"]"
    ]
  },
  "ty-settings": {
    "prefix": ".ty-pyproject",
    "body": [
      "[tool.ty.src]",
      "# チェック対象とするファイルパターン",
      "# include = []",
      "# 型チェック対象から除外するファイルパターン",
      "exclude = [\"tests/**\", \"migrations/**\"]",
      "# .gitignoreを尊重してチェック対象から除外する",
      "respect-ignore-files = true",
      "",
      "[tool.ty.terminal]",
      "# 警告レベルのみでも終了コード1は返さない",
      "error-on-warning = false",
      "# 結果のメッセージの表示する時の形式(full|concise)",
      "output-format = \"full\"",
      "",
      "[tool.ty.rules]",
      "# 型ヒントにバイト文字列を使うことを許さない",
      "byte-string-type-annotation = \"error\"",
      "# 呼び出し不可能なオブジェクトの呼び出しを許さない",
      "call-non-callable = \"error\"",
      "# 引数が値と型の両方の形式として使用されることを許さない",
      "conflicting-argument-forms=\"error\"",
      "# 変数が複数の型になりえる状態を許さない",
      "conflicting-declarations=\"error\"",
      "# 作成されるメタクラスが全てのクラスのベースのメタクラスのサブクラスにならないクラス定義を許さない",
      "conflicting-metaclass=\"error\"",
      "# 循環するクラス継承を許さない",
      "cyclic-class-definition=\"error\"",
      "# 自分自身を参照する型エイリアスを許さない",
      "cyclic-type-alias-definition=\"error\"",
      "# 継承するクラスが重複することを許さない",
      "duplicate-base=\"error\"",
      "# 複数のフィールドにdata class.KW_ONLY が型ヒントに指定することを許さない",
      "duplicate-kw-only=\"error\"",
      "# エスケープ文字を含む型ヒントを許さない",
      "escape-character-in-forward-annotation=\"error\"",
      "# 型ヒントにf文字列を使うことを許さない",
      "fstring-type-annotation=\"error\"",
      "# 型ヒントを文字列連結で指定することを許さない",
      "implicit-concatenated-string-type-annotation=\"error\"",
      "# メソッド解決順序が一貫していないクラスを許さない",
      "inconsistent-mro=\"error\"",
      "# 範囲外のインデックスを指定することを許さない",
      "index-out-of-bounds=\"error\"",
      "# __slots__で定義された属性が競合する継承を許さない",
      "instance-layout-conflict=\"error\"",
      "# 型ヒントに適合しない引数割当てを許さない",
      "invalid-argument-type=\"error\"",
      "# 変数の型ヒントと適合しない値の代入を許さない",
      "invalid-assignment=\"error\"",
      "# インスタンスからクラス変数への代入、クラスからインスタンス変数への代入を許さない",
      "invalid-attribute-access=\"error\"",
      "# 'await'をAwaitableでない型で使用することを許さない",
      "invalid-await=\"error\"",
      "# typeのインスタンスでないクラス定義を許さない",
      "invalid-base=\"error\"",
      "# コンテキストマネージャを実装していない型をwith文で使用することを許さない",
      "invalid-context-manager=\"error\"",
      "# 型推論された型が、型ヒント宣言と適合しないことを許さない",
      "invalid-declaration=\"error\"",
      "# 例外以外をcatchするexcept句は許さない",
      "invalid-exception-caught=\"error\"",
      "# @override装飾されているメソッドがオーバーライドしていないことを許さない",
      "invalid-explicit-override=\"error\"",
      "# frozenしていないdataclassを継承したdataclass(frozen有)を許さない",
      "invalid-frozen-dataclass-subclass=\"error\"",
      "# 無効なジェネリッククラスの作成を許さない",
      "invalid-generic-class=\"error\"",
      "# 無効なキーによる添字アクセスと、TypedDictに未定義キーでアクセスすることを許さない",
      "invalid-key=\"error\"",
      "# 無効なTypeVar定義を許さない",
      "invalid-legacy-type-variable=\"error\"",
      "# 無効なmetaclass引数の指定を許さない",
      "invalid-metaclass=\"error\"",
      "# リスコフの置換原則に違反するメソッドオーバーライドを許さない",
      "invalid-method-override=\"error\"",
      "# 無効なNamedTupleクラス定義を許さない",
      "invalid-named-tuple=\"error\"",
      "# 無効なNewType定義を許さない",
      "invalid-newtype=\"error\"",
      "# 無効な@overloadの使用を許さない",
      "invalid-overload=\"error\"",
      "# 引数のデフォルト値が型ヒントと適合しないことを許さない",
      "invalid-parameter-default=\"error\"",
      "# 無効なParamSpecの作成を許さない",
      "invalid-paramspec=\"error\"",
      "# 実行時にTypeErrorが発生するProtocolクラス定義を許さない",
      "invalid-protocol=\"error\"",
      "# 例外でないものをraiseする実装を許さない",
      "invalid-raise=\"error\"",
      "# 戻り値の型ヒントと適合しないreturn文を許さない",
      "invalid-return-type=\"error\"",
      "# 無効なsuper()の呼出しを許さない",
      "invalid-super-argument=\"error\"",
      "# 文字列をPython式として解析できない文字列リテラル注釈を許さない",
      "invalid-syntax-in-forward-annotation=\"error\"",
      "# 無効なTypeAliasTypeの定義を許さない",
      "invalid-type-alias-type=\"error\"",
      "# 明示的な型特殊化における無効な型引数を許さない",
      "invalid-type-arguments=\"error\"",
      "# TYPE_CHECKINGにbool以外の型を代入することを許さない",
      "invalid-type-checking-constant=\"error\"",
      "# 型として有効に解釈できない式を許さない",
      "invalid-type-form=\"error\"",
      "# 有効なターゲットのない型ガード関数呼び出しを許さない",
      "invalid-type-guard-call=\"error\"",
      "# 最初の(selfでない、キーワードでない、可変パラメータのない)型ガード関数をチェック",
      "invalid-type-guard-definition=\"error\"",
      "# 制約が2つ指定されていない型変数を許さない",
      "invalid-type-variable-constraints=\"error\"",
      "# 呼び出しに必要な引数が不足していることを許さない",
      "missing-argument=\"error\"",
      "# TypedDictコンストラクタ呼び出しでキーが不足していることを許さない",
      "missing-typed-dict-key=\"error\"",
      "# 一致するものがないオーバーロード関数の呼び出しを許さない",
      "no-matching-overload=\"error\"",
      "# 添字をサポートしていないオブジェクトに添字アクセスすることを許さない",
      "not-subscriptable=\"error\"",
      "# イテレートできないオブジェクトをイテレートすることを許さない",
      "not-iterable=\"error\"",
      "# @finalで装飾されたメソッドをオーバーライドすることを許さない",
      "override-of-final-method=\"error\"",
      "# 単一の引数に対して複数の引数を渡すことを許さない",
      "parameter-already-assigned=\"error\"",
      "# 位置引数にキーワードで値を渡すことを許さない",
      "positional-only-parameter-as-kwarg=\"error\"",
      "# 型ヒントにraw-stringを使用することを許さない",
      "raw-string-type-annotation=\"error\"",
      "# static_assertが静的にFalseであることを許さない",
      "static-assert-error=\"error\"",
      "# finalクラスを継承したfinalでないクラスを許さない",
      "subclass-of-final-class=\"error\"",
      "# NamedTupleクラスのメンバメソッド内でsuper()を呼び出すことを許さない",
      "super-call-in-named-tuple-method=\"error\"",
      "# 定義よりも多い位置引数を渡すことを許さない",
      "too-many-positional-arguments=\"error\"",
      "# assert_type()時に実際の型が異なることを許さない",
      "type-assertion-failure=\"error\"",
      "# 暗黙的な引数が利用できない無効な呼び出しを許さない",
      "unavailable-implicit-super-arguments=\"error\"",
      "# キーワード引数が一致するものがないことを許さない",
      "unknown-argument=\"error\"",
      "# 未解決な属性アクセスを許さない",
      "unresolved-attribute=\"error\"",
      "# 解決できないモジュールのインポートを許さない",
      "unresolved-import=\"error\"",
      "# 未定義な名前への参照を許さない",
      "unresolved-reference=\"error\"",
      "# __bool__が正しく実装されていないオブジェクトのbool変換を許さない",
      "unsupported-bool-conversion=\"error\"",
      "# 演算子をサポートしていないオブジェクトでの演算を許さない",
      "unsupported-operator=\"error\"",
      "# スライス内のステップサイズを0にすることを許さない",
      "zero-stepsize-in-slice=\"error\"",
      "# あいまいなプロトコルメンバの使用を警告する",
      "ambiguous-protocol-member=\"warn\"",
      "# 非推奨なアイテムの使用を警告する",
      "deprecated=\"warn\"",
      "# 未知の無視コメントを警告する",
      "ignore-comment-unknown-rule=\"warn\"",
      "# 無視コメントが正しくない構文であることを警告する",
      "invalid-ignore-comment=\"warn\"",
      "# 欠落している可能性のある属性を警告する",
      "possibly-missing-attribute=\"warn\"",
      "# 欠落している可能性のあるメソッドへの暗黙的呼び出しを警告する",
      "possibly-missing-implicit-call=\"warn\"",
      "# 欠落している可能性のあるシンボルのインポートを警告する",
      "possibly-missing-import=\"warn\"",
      "# 冗長な型キャストを警告する",
      "redundant-cast=\"warn\"",
      "# reveal_typeをインポートせずに呼び出すことを警告する",
      "undefined-reveal=\"warn\"",
      "# globalスコープに明示的な宣言がないことを警告する",
      "unresolved-global=\"warn\"",
      "# tyがサポートしていないベースを持つクラス定義を警告する",
      "unsupported-base=\"warn\"",
      "# @overloadスタブ本体以外のdecorated関数を警告する",
      "useless-overload-body=\"warn\"",
      "# ゼロ除算を警告する",
      "division-by-zero=\"ignore\"",
      "# 定義されていない可能性のある名前への参照は無視する",
      "possibly-unresolved-reference=\"ignore\"",
      "# 適用できなくなった無視コメントの存在は無視する",
      "unused-ignore-comment=\"ignore\"",
      "",
      "[tool.ty.environment]",
      "# モジュール解決で最優先で探索するユーザ指定のパス",
      "extra-paths = []",
      "# プロジェクトのPython環境またはインタープリターへのパス(uv以外を利用している場合に指定)",
      "# python = \"\"",
      "# コード解析に使用するプラットフォーム(win32|darwin|android|ios|linux|all)",
      "# python-platform = \"\"",
      "# コードの解析に使用するPythonバージョン(3.7|3.8|3.9|3.10|3.11|3.12|3.13|3.14)",
      "python-version = \"3.13\"",
      "# 1stPTモジュールの探索に使用されるプロジェクトルートのパス",
      "# root = []",
      "# 標準ライブラリの型に使用するディスク上の\"typeshed\"ディレクトリへのパス",
      "# typeshed = \"\"",
      "",
      "",
      "# 特定のパターンのみに適用するルール",
      "# [[tool.ty.overrides]]",
      "# オーバーライドする対象パターン",
      "# include =  [\"tests/**\", \"migrations/**\"]",
      "# オーバーライドから除外する対象パターン",
      "# exclude = []",
      "",
      "# 適用するルール",
      "# [tool.ty.overrides.rules]",
      ""
    ]
  },
  "mypy-settings": {
    "prefix": "mypy-pyproject",
    "body": [
      "[tool.mypy]",
      "# mypyプラグイン",
      "plugins = [\"pydantic.mypy\"]",
      "# チェックから除外する対象",
      "exclude = [\".venv/\", \"tests/\"]",
      "# 再帰的に型チェックしていくルールの指定(normal, silent, skip, error)",
      "follow_imports = \"silent\"",
      "# 無駄な型キャストを警告する",
      "warn_redundant_casts = true",
      "# errorを無視するコメントが、本来エラーが発生しない箇所にある場合に警告する",
      "warn_unused_ignores = true",
      "# 明示的な型パラメータを指定しないジェネリック型の使用を禁止する",
      "disallow_any_generics = true",
      "# 型ヒントの無い関数の内部を型チェックする",
      "check_untyped_defs = true",
      "# インポートしたモジュールを他のモジュールに再エクスポートさせない",
      "no_implicit_reexport = true",
      "# サードパーティ製モジュールの型アノテーションチェックを無効化",
      "ignore_missing_imports = true",
      "",
      "",
      "# mypy のpydanticプラグインの設定",
      "[tool.pydantic-mypy]",
      "# pydanticモデルの初期化時に未定義のフィールドを渡している場合に警告する",
      "init_forbid_extra = true",
      "# __init__メソッドの型チェックを行う",
      "init_typed = true",
      "# 必須フィールドに対して動的エイリアスを使用すると警告する",
      "warn_required_dynamic_aliases = true"
    ]
  }
}
