{
  "main": {
    "prefix": "def ",
    "body": [
      "def ${1:main}(${2}) -> ${3:None}:",
      "    $0"
    ],
    "description": "Define Function"
  },
  "if": {
    "prefix": "if ",
    "body": [
      "if ${1:condition}:",
      "    ${2:pass}"
    ],
    "description": "If 文"
  },
  "elif": {
    "prefix": "elif",
    "body": [
      "elif ${1:condition}:",
      "    ${2:pass}"
    ],
    "description": "Elif 句"
  },
  "else": {
    "prefix": "else",
    "body": [
      "else:",
      "    ${1:pass}"
    ],
    "description": "Else 句"
  },
  "match_case": {
    "prefix": "match",
    "body": [
      "match ${1:variable}:",
      "    case ${2:pattern_1}:",
      "        ${3:pass}",
      "    case _:",
      "        ${6:pass}"
    ],
    "description": "Match 文"
  },
  "__main__": {
    "prefix": "__n",
    "body": [
      " __name__ == \"__main__\""
    ],
    "description": "Entry Point"
  },
  "import": {
    "prefix": "imp",
    "body": [
      "import ${1:module}"
    ],
    "description": "Import 文"
  },
  "from_import": {
    "prefix": "from ",
    "body": [
      "from ${1:module} import ${2:item}"
    ],
    "description": "From Import 文"
  },
  "time_measure": {
    "prefix": ".time",
    "body": [
      "from typing import Callable, Any",
      "",
      "",
      "def measure_time(func: Callable) -> Any:",
      "    \"\"\"",
      "    関数の実行時間を計測するデコレータ",
      "    :param func: デコレートする関数",
      "    \"\"\"",
      "    import time",
      "    from functools import wraps",
      "",
      "    @wraps(func)",
      "    def wrapper(*args, **kwargs) -> Any:",
      "        \"\"\"",
      "        関数の実行時間を計測するラッパー関数",
      "        \"\"\"",
      "        start = time.perf_counter()",
      "        result = func(*args, **kwargs)",
      "        elapsed_time = time.perf_counter() - start",
      "        print(f\"{func.__name__} took {elapsed_time} seconds.\")",
      "        return result",
      "",
      "        return wrapper"
    ]
  }
}
