{
    "global": { "show_additional_menu_items": true },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "NeovimではIMEをskkeletonを使う",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.github\\.wez\\.wezterm",
                                            "^com\\.mitchellh\\.ghostty"
                                        ],
                                        "type": "frontmost_application_if"
                                    },
                                    {
                                        "name": "on_neovim",
                                        "type": "variable_if",
                                        "value": 1
                                    }
                                ],
                                "from": { "key_code": "japanese_kana" },
                                "to": [
                                    {
                                        "key_code": "j",
                                        "modifiers": ["left_control", "left_option", "left_shift"]
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.github\\.wez\\.wezterm",
                                            "^com\\.mitchellh\\.ghostty"
                                        ],
                                        "type": "frontmost_application_if"
                                    },
                                    {
                                        "name": "on_neovim",
                                        "type": "variable_if",
                                        "value": 1
                                    }
                                ],
                                "from": { "key_code": "japanese_eisuu" },
                                "to": [
                                    {
                                        "key_code": "e",
                                        "modifiers": ["left_control", "left_option", "left_shift"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "コマンドキーを単体で押したときに、英数・かなキーを送信する。（左コマンドキーは英数、右コマンドキーはかな）",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "left_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_command" }],
                                "to_if_alone": [{ "key_code": "japanese_eisuu" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "right_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "right_command" }],
                                "to_if_alone": [{ "key_code": "japanese_kana" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "SandS: Change ␣ to R⇧ (if alone)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "spacebar",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "right_shift" }],
                                "to_if_alone": [{ "key_code": "spacebar" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "escキーを押したときに、入力モードを英語(macSKK)にする",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "input_sources": [
                                            {
                                                "input_mode_id": "net.mtgto.inputmethod.macSKK.hiragana",
                                                "input_source_id": "net.mtgto.inputmethod.macSKK.hiragana",
                                                "language": "ja"
                                            }
                                        ],
                                        "type": "input_source_if"
                                    }
                                ],
                                "from": { "key_code": "escape" },
                                "to": [
                                    { "key_code": "escape" },
                                    {
                                        "select_input_source": {
                                            "input_source_id": "com.apple.keylayout.ABC",
                                            "language": "en"
                                        }
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "devices": [
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "is_pointing_device": true,
                        "product_id": 100,
                        "vendor_id": 14289
                    },
                    "ignore": false,
                    "ignore_vendor_events": true,
                    "manipulate_caps_lock_led": false
                },
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "product_id": 6,
                        "vendor_id": 22854
                    },
                    "ignore_vendor_events": true,
                    "manipulate_caps_lock_led": false
                }
            ],
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}
