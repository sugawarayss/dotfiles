{
  "mcpServers": {
    "aws-knowledge-mcp-server": {
      "args": [
        "fastmcp",
        "run",
        "https://knowledge-mcp.global.api.aws"
      ],
      "autoApprove": [
        "aws___get_regional_availability",
        "aws___list_regions",
        "aws___read_documentation",
        "aws___recommend",
        "aws___search_documentation"
      ],
      "command": "uvx"
    },
    "aws-terraform-mcp-server": {
      "args": [
        "awslabs.terraform-mcp-server@latest"
      ],
      "autoApprove": [
        "ExecuteTerraformCommand",
        "SearchAwsProviderDocs",
        "SearchAwsccProviderDocs",
        "SearchSpecificAwsIaModules",
        "SearchUserProvidedModule",
        "RunCheckovScan",
        "ExecuteTerragruntCommand"
      ],
      "command": "uvx",
      "disabled": false,
      "disabled_tools": [],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${ALLOWED_DIRECTORY}"
      ],
      "autoApprove": [],
      "command": "npx",
      "env": {
        "ALLOWED_DIRECTORY": "~/PROJECTS/"
      }
    },
    "sequentialthinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "autoApprove": [
        "sequentialthinking"
      ],
      "command": "npx"
    },
    "serena": {
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "autoApprove": [
        "list_dir",
        "find_file",
        "search_for_pattern",
        "get_symbols_overview",
        "find_symbol",
        "find_referencing_symbols",
        "replace_symbol_body",
        "insert_after_symbol",
        "insert_before_symbol",
        "rename_symbol",
        "write_memory",
        "read_memory",
        "list_memories",
        "delete_memory",
        "edit_memory",
        "activate_project",
        "get_current_config",
        "check_onboarding_performed",
        "onboarding",
        "think_about_collected_information",
        "think_about_task_adherence",
        "think_about_whether_you_are_done",
        "initial_instructions"
      ],
      "command": "uvx"
    }
  },
  "nativeMCPServers": {
    "mcphub": {
      "autoApprove": [
        "get_current_servers",
        "toggle_mcp_server"
      ],
      "disabled_prompts": [
        "create_native_server"
      ],
      "disabled_resources": [
        "mcphub://native_server_guide",
        "mcphub://changelog"
      ]
    },
    "neovim": {
      "autoApprove": [
        "edit_file",
        "execute_command",
        "execute_lua",
        "find_files",
        "list_directory",
        "move_item",
        "read_file",
        "read_multiple_files",
        "write_file"
      ],
      "disabled_prompts": [
        "parrot"
      ],
      "disabled_resources": [],
      "disabled_tools": [
        "delete_items"
      ]
    }
  }
}
