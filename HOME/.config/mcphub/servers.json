{
  "mcpServers": {
    "aws-knowledge-mcp-server": {
      "args": [
        "fastmcp",
        "run",
        "https://knowledge-mcp.global.api.aws"
      ],
      "autoApprove": [
        "aws___get_regional_availability",
        "aws___list_regions",
        "aws___read_documentation",
        "aws___recommend",
        "aws___search_documentation"
      ],
      "command": "uvx"
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "autoApprove": [
        "query-docs",
        "resolve-library-id"
      ],
      "command": "npx",
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "128000"
      }
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${ALLOWED_DIRECTORY}"
      ],
      "autoApprove": [
        "get_file_info",
        "list_directory",
        "list_directory_with_sizes",
        "list_allowed_directories",
        "read_file",
        "read_media_file",
        "read_multiple_files",
        "read_text_file",
        "search_files",
        "directory_tree",
        "create_directory",
        "write_file"
      ],
      "command": "npx",
      "env": {
        "ALLOWED_DIRECTORY": "~/PROJECTS/"
      }
    },
    "markitdown": {
      "args": [
        "markitdown-mcp==0.0.1a4"
      ],
      "autoApprove": [
        "convert_to_markdown"
      ],
      "command": "uvx",
      "type": "stdio"
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
      "autoApprove": [
        "browser_click",
        "browser_wait_for",
        "browser_type",
        "browser_take_screenshot",
        "browser_press_key",
        "browser_hover",
        "browser_evaluate",
        "browser_drag",
        "browser_console_messages",
        "browser_close"
      ],
      "command": "npx"
    },
    "serena": {
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide"
      ],
      "autoApprove": [
        "list_dir",
        "find_file",
        "search_for_pattern",
        "get_symbols_overview",
        "find_symbol",
        "find_referencing_symbols",
        "replace_symbol_body",
        "insert_after_symbol",
        "insert_before_symbol",
        "rename_symbol",
        "write_memory",
        "read_memory",
        "list_memories",
        "delete_memory",
        "edit_memory",
        "activate_project",
        "get_current_config",
        "check_onboarding_performed",
        "onboarding",
        "think_about_collected_information",
        "think_about_task_adherence",
        "think_about_whether_you_are_done",
        "initial_instructions"
      ],
      "command": "uvx"
    },
    "serverless": {
      "args": [
        "mcp"
      ],
      "autoApprove": [
        "docs",
        "aws-lambda-info",
        "aws-iam-info",
        "aws-cloudwatch-alarms",
        "aws-rest-api-gateway-info",
        "list-projects",
        "service-summary",
        "list-resources",
        "deployment-history",
        "aws-logs-tail",
        "aws-logs-search",
        "aws-errors-info"
      ],
      "command": "serverless",
      "disabled": false,
      "disabled_tools": []
    },
    "terraform": {
      "args": [
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ],
      "autoApprove": [
        "get_latest_module_version",
        "get_latest_provider_version",
        "get_module_details",
        "get_policy_details",
        "get_provider_details",
        "search_modules",
        "search_policies",
        "search_providers"
      ],
      "command": "docker",
      "disabled_resourceTemplates": [],
      "type": "stdio"
    }
  },
  "nativeMCPServers": {
    "mcphub": {
      "autoApprove": [
        "get_current_servers",
        "toggle_mcp_server"
      ],
      "disabled_prompts": [
        "create_native_server"
      ],
      "disabled_resources": [
        "mcphub://native_server_guide",
        "mcphub://changelog"
      ]
    },
    "neovim": {
      "autoApprove": [
        "edit_file",
        "execute_command",
        "execute_lua",
        "find_files",
        "list_directory",
        "move_item",
        "read_file",
        "read_multiple_files",
        "write_file"
      ],
      "disabled_prompts": [
        "parrot"
      ],
      "disabled_resources": [],
      "disabled_tools": [
        "delete_items"
      ]
    }
  }
}
