{
  "mcpServers": {
    "aws-knowledge-mcp-server": {
      "args": [
        "fastmcp",
        "run",
        "https://knowledge-mcp.global.api.aws"
      ],
      "autoApprove": [
        "aws___search_documentation",
        "aws___recommend",
        "aws___read_documentation",
        "aws___get_regional_availability",
        "aws___list_regions"
      ],
      "command": "uvx"
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${ALLOWED_DIRECTORY}"
      ],
      "autoApprove": [
        "list_allowed_directories",
        "list_directory",
        "read_file",
        "read_media_file",
        "read_multiple_files",
        "read_text_file",
        "search_files",
        "write_file",
        "edit_file",
        "directory_tree",
        "create_directory",
        "get_file_info",
        "list_directory_with_sizes",
        "move_file"
      ],
      "command": "npx",
      "env": {
        "ALLOWED_DIRECTORY": "~/PROJECTS/"
      }
    },
    "sequentialthinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "autoApprove": [
        "sequentialthinking"
      ],
      "command": "npx"
    },
    "serena": {
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "autoApprove": [
        "find_file",
        "find_symbol",
        "list_dir",
        "read_memory",
        "write_memory",
        "list_memories",
        "think_about_collected_information",
        "activate_project",
        "onboarding",
        "search_for_pattern",
        "think_about_task_adherence",
        "delete_memory",
        "find_referencing_symbols",
        "get_symbols_overview",
        "insert_after_symbol",
        "insert_before_symbol",
        "replace_symbol_body",
        "think_about_whether_you_are_done",
        "check_onboarding_performed",
        "get_current_config"
      ],
      "command": "uvx"
    },
    "tavily": {
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "autoApprove": [
        "tavily-search",
        "tavily-map",
        "tavily-extract",
        "tavily-crawl"
      ],
      "command": "npx",
      "env": {
        "TAVILY_API_KEY": ""
      }
    }
  },
  "nativeMCPServers": {
    "mcphub": {
      "autoApprove": [
        "get_current_servers",
        "toggle_mcp_server"
      ],
      "disabled_prompts": [
        "create_native_server"
      ],
      "disabled_resources": [
        "mcphub://native_server_guide",
        "mcphub://changelog"
      ]
    },
    "neovim": {
      "autoApprove": [
        "execute_command",
        "find_files",
        "list_directory",
        "read_file",
        "read_multiple_files",
        "write_file",
        "move_item",
        "edit_file"
      ],
      "disabled_prompts": [
        "parrot"
      ],
      "disabled_resources": [],
      "disabled_tools": [
        "delete_items"
      ]
    }
  }
}
