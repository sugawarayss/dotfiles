{
  "mcpServers": {
    "aws-knowledge": {
      "args": [
        "fastmcp",
        "run",
        "https://knowledge-mcp.global.api.aws"
      ],
      "autoApprove": [
        "aws___get_regional_availability",
        "aws___list_regions",
        "aws___read_documentation",
        "aws___recommend",
        "aws___search_documentation"
      ],
      "command": "uvx"
    },
    "chrome-devtools": {
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "autoApprove": [
        "click",
        "close_page",
        "drag",
        "emulate",
        "evaluate_script",
        "fill",
        "fill_form",
        "get_console_message",
        "get_network_request",
        "handle_dialog",
        "hover",
        "lighthouse_audit",
        "list_console_messages",
        "list_network_requests",
        "list_pages",
        "navigate_page",
        "new_page",
        "performance_analyze_insight",
        "performance_start_trace",
        "performance_stop_trace",
        "press_key",
        "resize_page",
        "select_page",
        "take_heapsnapshot",
        "take_screenshot",
        "take_snapshot",
        "type_text",
        "upload_file",
        "wait_for"
      ],
      "command": "npx",
      "type": "stdio"
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "autoApprove": [
        "query-docs",
        "resolve-library-id"
      ],
      "command": "npx",
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "128000"
      }
    },
    "markitdown": {
      "args": [
        "markitdown-mcp==0.0.1a4"
      ],
      "autoApprove": [
        "convert_to_markdown"
      ],
      "command": "uvx",
      "type": "stdio"
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
      "autoApprove": [
        "browser_close",
        "browser_resize",
        "browser_console_messages",
        "browser_handle_dialog",
        "browser_evaluate",
        "browser_file_upload",
        "browser_drop",
        "browser_fill_form",
        "browser_press_key",
        "browser_type",
        "browser_navigate",
        "browser_navigate_back",
        "browser_network_requests",
        "browser_network_request",
        "browser_run_code_unsafe",
        "browser_take_screenshot",
        "browser_snapshot",
        "browser_click",
        "browser_drag",
        "browser_hover",
        "browser_select_option",
        "browser_tabs",
        "browser_wait_for"
      ],
      "command": "npx"
    },
    "serena": {
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide"
      ],
      "autoApprove": [
        "replace_content",
        "replace_in_files",
        "replace_symbol_body",
        "insert_after_symbol",
        "insert_before_symbol",
        "search_for_pattern",
        "get_symbols_overview",
        "find_symbol",
        "find_referencing_symbols",
        "find_implementations",
        "find_declaration",
        "get_diagnostics_for_file",
        "rename_symbol",
        "safe_delete_symbol",
        "write_memory",
        "read_memory",
        "list_memories",
        "delete_memory",
        "rename_memory",
        "edit_memory",
        "open_dashboard",
        "activate_project",
        "get_current_config",
        "onboarding",
        "initial_instructions"
      ],
      "command": "uvx"
    },
    "serverless": {
      "args": [
        "mcp"
      ],
      "autoApprove": [
        "docs",
        "aws-lambda-info",
        "aws-iam-info",
        "aws-cloudwatch-alarms",
        "aws-rest-api-gateway-info",
        "list-projects",
        "service-summary",
        "list-resources",
        "deployment-history",
        "aws-logs-tail",
        "aws-logs-search",
        "aws-errors-info"
      ],
      "command": "serverless",
      "disabled": false,
      "disabled_tools": []
    },
    "terraform": {
      "args": [
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ],
      "autoApprove": [
        "get_latest_module_version",
        "get_latest_provider_version",
        "get_module_details",
        "get_policy_details",
        "get_provider_details",
        "search_modules",
        "search_policies",
        "search_providers"
      ],
      "command": "docker",
      "disabled_resourceTemplates": [],
      "type": "stdio"
    }
  },
  "nativeMCPServers": {
    "mcphub": {
      "autoApprove": [
        "get_current_servers",
        "toggle_mcp_server"
      ],
      "disabled_prompts": [
        "create_native_server"
      ],
      "disabled_resources": [
        "mcphub://native_server_guide",
        "mcphub://changelog"
      ]
    },
    "neovim": {
      "autoApprove": [
        "edit_file",
        "execute_command",
        "execute_lua",
        "find_files",
        "list_directory",
        "move_item",
        "read_file",
        "read_multiple_files",
        "write_file"
      ],
      "disabled_prompts": [
        "parrot"
      ],
      "disabled_resources": [],
      "disabled_tools": [
        "delete_items"
      ]
    }
  }
}
