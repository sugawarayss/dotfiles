// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: [https://zed.dev/docs/key-bindings](https://zed.dev/docs/key-bindings)
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // コマンドパレットのトグル
      "cmd-shift-p": "command_palette::Toggle",
      // プロジェクトパネル(ファイルエクスプローラへのフォーカスをトグル)
      // "ctrl-t ctrl-": "project_panel::ToggleFocus",
      // ファイルファインダーのトグル
      "shift shift": "file_finder::Toggle",
      // アシスタントパネルのトグル
      // "space c c": "assistant::Toggle",
      // 下側(Terminal用)のDockをトグル
      "f3": "workspace::ToggleBottomDock",
      // タブスイッチャーのトグル
      "ctrl-tab": "tab_switcher::Toggle",
      // アウトラインの表示
      "space o l": "outline::Toggle"
    }
  },
  {
    // spaceをLeader キーとして使うため 空白入力と衝突回避
    "context": "Workspace && (vim_mode == normal)",
    "bindings": {
      // 左側のDockをトグル
      "space f e": "workspace::ToggleLeftDock",
      // 右側k(AI Chat用)のDockをトグル
      "space c c": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "shift-a": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": ["project_panel::Trash", { "skip_prompt": false }],
      "space e": "project_panel::ToggleFocus",
      "ctrl-shift-enter": null,
      // 左側のDockをトグル
      "space f e": "workspace::ToggleLeftDock",
      // ペインの分割 直接分割はなさそう。。。
      "ctrl-k": "project_panel::Open"
      // "ctrl-j": "pane::SplitDown",
      // "ctrl-l": "pane::SplitRight",
      // "ctrl-h": "pane::SplitLeft"
    }
  },
  {
    "context": "FileFinder && !menu_open",
    "bindings": {
      "shift shift": "file_finder::Toggle",
      "ctrl-j": "pane::SplitDown",
      "ctrl-k": "pane::SplitUp",
      "ctrl-h": "pane::SplitLeft",
      "ctrl-l": "pane::SplitRight"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-m": null,
      "alt-cmd-[": null,
      "alt-cmd-]": null
    }
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      // 検索モードのトグル
      "cmd-f": "buffer_search::Deploy",
      // 置換モードのトグル
      "cmd-alt-f": ["buffer_search::Deploy", { "replace_enabled": true }]
    }
  },
  {
    "context": "Editor && (vim_mode == normal) && !menu",
    "bindings": {
      "u": "editor::Undo",
      "shift-u": "editor::Redo",
      // 左側のDockをトグル
      "space f e": "workspace::ToggleLeftDock",
      // 右側k(AI Chat用)のDockをトグル
      "space c c": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !menu",
    "bindings": {
      // コードアクション候補を表示
      "g a": "editor::ToggleCodeActions",
      // 行番号表示トグルを無効化
      "cmd-;": null,
      // ペインの分割
      "ctrl-k": "pane::SplitUp",
      "ctrl-j": "pane::SplitDown",
      "ctrl-l": "pane::SplitRight",
      "ctrl-h": "pane::SplitLeft",
      // アクティブなPaneの移動
      "alt-h": "workspace::ActivatePaneLeft",
      "alt-l": "workspace::ActivatePaneRight",
      "alt-k": "workspace::ActivatePaneUp",
      "alt-j": "workspace::ActivatePaneDown",
      // タブ選択
      "shift-l": "pane::ActivateNextItem",
      "shift-h": "pane::ActivatePreviousItem",
      // lazygitを起動
      "space g g": [
        "task::Spawn",
        { "task_name": "lazygit", "reveal_target": "center" }
      ],
      "ctrl-t ctrl-t": [
        "task::Spawn",
        { "task_name": "yazi", "reveal_target": "center" }
      ]
    }
  }
]
